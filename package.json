{
  "name": "marina-pearl-dental",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Marina Pearl Dental Clinic — public site, guest booking, staff admin.",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:frontend dev:backend",
    "dev:frontend": "npm --workspace frontend run dev",
    "dev:backend": "npm --workspace backend run dev",
    "build": "npm --workspace frontend run build",
    "start": "npm --workspace backend run start",
    "seed": "npm --workspace backend run seed"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "engines": {
    "node": ">=20.6"
  }
}
