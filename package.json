{
  "name": "marina-pearl-dental",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Marina Pearl Dental Clinic — public site, guest booking, staff admin.",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:client dev:server",
    "dev:client": "npm --workspace client run dev",
    "dev:server": "npm --workspace server run dev",
    "build": "npm --workspace client run build",
    "start": "npm --workspace server run start",
    "seed": "npm --workspace server run seed"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "engines": {
    "node": ">=20.6"
  }
}
