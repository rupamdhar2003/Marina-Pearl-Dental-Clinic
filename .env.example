# =========================================
# Marina Pearl Dental Clinic — env template
# Copy to .env at the repo root before running.
# =========================================

# ---- Supabase ----
# Create a project at https://supabase.com then paste the values from
# Project Settings → API. The service-role key is server-only.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Client-visible copies (Vite requires VITE_ prefix) ----
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# In local dev, point the client at the Express dev server.
# On Vercel, leave this blank so the client fetches same-origin (/api/*).
VITE_API_BASE_URL=http://localhost:5174

# ---- Server ----
# API_PORT overrides PORT so ambient dev tooling that sets PORT for the
# client (e.g. hosted previewers) doesn't push Express onto Vite's port.
API_PORT=5174
NODE_ENV=development
CORS_ALLOWED_ORIGIN=http://localhost:5173

# ---- Seed staff user (created by npm run seed) ----
SEED_STAFF_EMAIL=admin@marinapearldental.example
SEED_STAFF_PASSWORD=ChangeMe!Str0ng2025

# ---- Web3Forms (contact form) ----
# Get an access key at https://web3forms.com
WEB3FORMS_ACCESS_KEY=your-web3forms-access-key

# ---- Email (choose one; stubbed if unset) ----
# Resend (https://resend.com)
RESEND_API_KEY=
EMAIL_FROM=hello@marinapearldental.example
EMAIL_PROVIDER=resend

# ---- Public site URL (used in confirmation emails / reschedule links) ----
PUBLIC_SITE_URL=http://localhost:5173
